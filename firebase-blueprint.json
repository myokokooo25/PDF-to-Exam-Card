{
  "schemas": {
    "sessions": {
      "id": "string",
      "userId": "string",
      "fileName": "string",
      "timestamp": "number",
      "mode": "string",
      "data": "array",
      "translationData": "array",
      "vocabData": "array"
    },
    "users": {
      "uid": "string",
      "email": "string",
      "displayName": "string",
      "photoURL": "string",
      "createdAt": "number"
    }
  },
  "rules": {
    "sessions": {
      "read": "request.auth != null && resource.data.userId == request.auth.uid",
      "write": "request.auth != null && request.resource.data.userId == request.auth.uid"
    },
    "users": {
      "read": "request.auth != null && resource.id == request.auth.uid",
      "write": "request.auth != null && request.resource.id == request.auth.uid"
    }
  }
}
